<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nazanin Talei | Marketing & Product Portfolio</title>
  <style>
    :root {
      --bg: #0b1020;
      --bg-soft: rgba(255,255,255,0.06);
      --card: rgba(255,255,255,0.08);
      --text: #eef2ff;
      --muted: #b9c0dd;
      --line: rgba(255,255,255,0.14);
      --accent: #8b5cf6;
      --accent-2: #22c55e;
      --accent-3: #f59e0b;
      --shadow: 0 18px 50px rgba(0,0,0,0.32);
      --radius: 24px;
      --max: 1180px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(139,92,246,0.22), transparent 28%),
        radial-gradient(circle at top right, rgba(34,197,94,0.15), transparent 24%),
        radial-gradient(circle at 20% 80%, rgba(245,158,11,0.14), transparent 22%),
        linear-gradient(180deg, #0b1020 0%, #11182d 52%, #0c1223 100%);
      min-height: 100vh;
      overflow-x: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
      background-size: 28px 28px;
      mask-image: linear-gradient(to bottom, rgba(0,0,0,0.35), transparent 78%);
    }

    .container { width: min(var(--max), calc(100% - 32px)); margin: 0 auto; }

    .nav-wrap {
      position: sticky;
      top: 14px;
      z-index: 20;
      padding: 14px 0 0;
    }

    nav {
      width: min(920px, calc(100% - 24px));
      margin: 0 auto;
      background: rgba(11,16,32,0.58);
      border: 1px solid var(--line);
      backdrop-filter: blur(18px);
      border-radius: 999px;
      box-shadow: var(--shadow);
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 18px;
    }

    .brand {
      display: flex; gap: 10px; align-items: center; font-weight: 700; letter-spacing: 0.2px;
    }

    .brand-badge {
      width: 36px; height: 36px; border-radius: 12px;
      display: grid; place-items: center;
      background: linear-gradient(135deg, var(--accent), #c084fc);
      box-shadow: 0 10px 30px rgba(139,92,246,0.35);
      font-weight: 800;
    }

    nav ul { list-style: none; display: flex; gap: 18px; padding: 0; margin: 0; }
    nav a { color: var(--muted); text-decoration: none; font-size: 0.95rem; }
    nav a:hover { color: white; }

    .cta {
      display: inline-flex; align-items: center; gap: 10px;
      padding: 12px 18px; border-radius: 999px; border: 1px solid transparent;
      background: linear-gradient(135deg, var(--accent), #6d28d9);
      color: white; text-decoration: none; font-weight: 700;
      box-shadow: 0 12px 28px rgba(109,40,217,0.34);
      transition: transform .25s ease, box-shadow .25s ease;
    }
    .cta:hover { transform: translateY(-2px); box-shadow: 0 16px 30px rgba(109,40,217,0.4); }
    .cta.secondary {
      background: transparent; border-color: var(--line); color: var(--text);
      box-shadow: none;
    }

    header.hero { padding: 88px 0 56px; position: relative; }
    .hero-grid {
      display: grid; grid-template-columns: 1.2fr .8fr; gap: 28px; align-items: center;
    }

    .eyebrow {
      display: inline-flex; align-items: center; gap: 10px;
      padding: 8px 14px; border-radius: 999px; border: 1px solid var(--line);
      background: rgba(255,255,255,0.05); color: #d8ddf5; font-size: 0.92rem;
      margin-bottom: 18px;
    }

    h1 {
      margin: 0 0 16px;
      font-size: clamp(2.8rem, 6vw, 5.5rem);
      line-height: 0.97;
      letter-spacing: -0.06em;
    }

    .gradient-text {
      background: linear-gradient(90deg, #fff, #c4b5fd 38%, #86efac 78%, #fde68a);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .hero p {
      color: var(--muted);
      font-size: 1.08rem;
      line-height: 1.75;
      max-width: 720px;
      margin: 0 0 22px;
    }

    .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; margin: 26px 0 30px; }

    .stats {
      display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 14px;
    }

    .stat {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 20px;
      padding: 18px;
      box-shadow: var(--shadow);
    }
    .stat strong { display: block; font-size: 1.6rem; margin-bottom: 8px; }
    .stat span { color: var(--muted); font-size: 0.95rem; }

    .hero-card {
      position: relative;
      background: linear-gradient(180deg, rgba(255,255,255,0.12), rgba(255,255,255,0.06));
      border: 1px solid var(--line);
      border-radius: 32px;
      padding: 26px;
      box-shadow: var(--shadow);
      overflow: hidden;
      transform: translateY(0);
      animation: float 6s ease-in-out infinite;
    }

    .hero-card::before {
      content: "";
      position: absolute;
      width: 220px;
      height: 220px;
      border-radius: 50%;
      top: -70px; right: -70px;
      background: radial-gradient(circle, rgba(139,92,246,0.4), transparent 65%);
    }

    .mock-window {
      position: relative;
      background: rgba(9,13,25,0.66);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 24px;
      padding: 18px;
      overflow: hidden;
    }
    .window-dots { display: flex; gap: 8px; margin-bottom: 14px; }
    .window-dots span { width: 10px; height: 10px; border-radius: 50%; background: rgba(255,255,255,0.24); }
    .card-stack { display: grid; gap: 12px; }
    .mini-card {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 18px;
      padding: 14px;
    }
    .mini-card h4 { margin: 0 0 8px; font-size: 0.98rem; }
    .mini-card p { margin: 0; color: var(--muted); font-size: 0.9rem; line-height: 1.5; }

    section { padding: 34px 0 72px; }
    .section-head {
      display: flex; justify-content: space-between; gap: 20px; align-items: end; margin-bottom: 26px; flex-wrap: wrap;
    }
    .section-head h2 {
      font-size: clamp(2rem, 4vw, 3.2rem);
      letter-spacing: -0.04em;
      margin: 0;
    }
    .section-head p { color: var(--muted); max-width: 650px; margin: 0; line-height: 1.7; }

    .grid-3 { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 18px; }
    .grid-2 { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 18px; }

    .panel {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 24px;
      box-shadow: var(--shadow);
      transition: transform .25s ease, border-color .25s ease, background .25s ease;
    }
    .panel:hover {
      transform: translateY(-4px);
      border-color: rgba(255,255,255,0.22);
      background: rgba(255,255,255,0.1);
    }

    .tag {
      display: inline-flex; padding: 7px 12px; border-radius: 999px; font-size: 0.84rem;
      color: #efe9ff; background: rgba(139,92,246,0.18); border: 1px solid rgba(196,181,253,0.22);
      margin-bottom: 14px;
    }

    .project-title {
      display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 10px;
    }
    .project-title h3, .panel h3 { margin: 0; font-size: 1.24rem; }
    .project-title span { color: #f0f4ff; font-size: 0.92rem; }
    .panel p { color: var(--muted); line-height: 1.75; }

    .metric-row {
      display: flex; flex-wrap: wrap; gap: 10px; margin-top: 16px;
    }
    .metric {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 14px;
      padding: 10px 12px;
      color: #eef2ff;
      font-size: 0.92rem;
    }

    .skill-pill-wrap { display: flex; flex-wrap: wrap; gap: 10px; }
    .skill-pill {
      background: rgba(255,255,255,0.06);
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 10px 14px;
      color: #e8ebff;
      font-size: 0.95rem;
    }

    .timeline { display: grid; gap: 16px; }
    .timeline-item {
      display: grid; grid-template-columns: 120px 1fr; gap: 18px; align-items: start;
      padding: 18px; border-radius: 20px; background: rgba(255,255,255,0.05); border: 1px solid var(--line);
    }
    .timeline-item .year { color: #c4b5fd; font-weight: 700; }
    .timeline-item h4 { margin: 0 0 8px; font-size: 1.05rem; }
    .timeline-item p { margin: 0; color: var(--muted); }

    .contact-box {
      background: linear-gradient(135deg, rgba(139,92,246,0.18), rgba(255,255,255,0.08));
      border: 1px solid var(--line);
      border-radius: 32px;
      padding: 28px;
      box-shadow: var(--shadow);
      display: grid; grid-template-columns: 1.2fr .8fr; gap: 18px; align-items: center;
    }

    .contact-links { display: flex; flex-wrap: wrap; gap: 12px; }
    .link-card {
      text-decoration: none; color: var(--text);
      display: inline-flex; align-items: center; gap: 10px;
      padding: 14px 16px; border-radius: 18px; border: 1px solid var(--line); background: rgba(255,255,255,0.06);
    }

    footer {
      padding: 18px 0 48px;
      color: rgba(255,255,255,0.65);
      text-align: center;
      font-size: 0.95rem;
    }

    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity .8s ease, transform .8s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    @keyframes float {
      0%,100% { transform: translateY(0px); }
      50% { transform: translateY(-10px); }
    }

    @media (max-width: 980px) {
      .hero-grid, .contact-box, .grid-3, .grid-2 { grid-template-columns: 1fr; }
      nav ul { display: none; }
      .stats { grid-template-columns: 1fr; }
    }

    @media (max-width: 640px) {
      .container { width: min(var(--max), calc(100% - 20px)); }
      header.hero { padding-top: 64px; }
      .panel, .hero-card, .contact-box { padding: 20px; }
      .timeline-item { grid-template-columns: 1fr; }
      nav { border-radius: 24px; }
    }
  </style>
</head>
